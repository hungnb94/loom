{
  "hooks": {
    "Start": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/start_pipeline.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/check_pipeline.py"
          }
        ]
      }
    ]
  }
}
